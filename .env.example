# Server (local development)
PORT=4000
HOST=0.0.0.0

# Admin panel — overrides default seed password on first database init
ADMIN_PASSWORD=change-me

# Frontend dev proxy target (optional; defaults to http://localhost:4000)
# VITE_API_URL=http://localhost:4000

# Media audit script base URL (optional)
# MEDIA_BASE=http://localhost:4000

# Set automatically on Vercel — do not set locally unless testing serverless behavior
# VERCEL=1
