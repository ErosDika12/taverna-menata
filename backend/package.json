{
  "name": "taverna-menata-backend",
  "version": "1.0.0",
  "private": true,
  "description": "API server for the Taverna Menata website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "reseed": "node db.js",
    "apply-i18n": "node -e \"require('./db'); require('./ensure-i18n').ensureI18n(require('./db'));\"",
    "media-audit": "node ../scripts/media-audit.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1"
  }
}
